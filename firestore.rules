rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn(); } // Relaxed verified check for preview environment
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- Entities ---

    // Users
    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && userId == request.auth.uid;
      allow update: if isSignedIn() && userId == request.auth.uid;
    }

    // Makers
    match /makers/{makerId} {
      allow read: if true;
      allow create: if isSignedIn();
    }

    // Anime
    match /anime/{animeId} {
      allow read: if true;
      allow create: if isSignedIn();
    }

    // Action Figures
    match /actionFigures/{figureId} {
      function isValidFigure(data) {
        return data.userId is string
          && data.characterName is string
          && data.maker is string
          && data.totalPrice is number
          && data.sourceAnime is string;
      }

      allow read: if true;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidFigure(incoming());
      allow update: if isSignedIn() && existing().userId == request.auth.uid && incoming().userId == request.auth.uid && isValidFigure(incoming());
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // Preorders
    match /preorders/{preorderId} {
      function isValidPreorder(data) {
        return data.userId is string
          && data.figureName is string
          && data.seller is string
          && data.preorderPrice is number
          && data.downpayment is number;
      }
      allow read: if true;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidPreorder(incoming());
      allow update: if isSignedIn() && existing().userId == request.auth.uid && incoming().userId == request.auth.uid && isValidPreorder(incoming());
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // Equipments
    match /equipments/{equipmentId} {
      function isValidEquipment(data) {
        return data.userId is string
          && data.description is string
          && data.totalPrice is number;
      }
      allow read: if true;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidEquipment(incoming());
      allow update: if isSignedIn() && existing().userId == request.auth.uid && incoming().userId == request.auth.uid && isValidEquipment(incoming());
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // Showcases
    match /showcases/{showcaseId} {
      function isValidShowcase(data) {
        return data.userId is string
          && data.name is string
          && data.name.size() <= 100
          && data.description is string
          && data.description.size() <= 1000;
      }
      allow read: if true; // Publicly viewable
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidShowcase(incoming());
      allow update: if isSignedIn() && existing().userId == request.auth.uid && incoming().userId == request.auth.uid && isValidShowcase(incoming());
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
